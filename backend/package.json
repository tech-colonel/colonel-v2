    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "multer": "^2.1.1",
    "once": "^1.4.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "uuid": "^13.0.0",
    "validator": "^13.15.26",
    "wrappy": "^1.0.2",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.2"
