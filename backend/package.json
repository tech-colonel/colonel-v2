{
  "name": "colonel-v2-backend",
  "version": "1.0.0",
  "description": "Colonel V2 - Single DB multi-tenant e-commerce analytics platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "npx sequelize-cli db:migrate",
